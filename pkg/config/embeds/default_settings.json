{
  "active_profile": "local",
  "default_template": "gemini",
  "runtimes": {
    "docker": {
      "host": ""
    },
    "container": {
      "tmux": true
    },
    "kubernetes": {
      "context": "",
      "namespace": ""
    }
  },
  "harnesses": {
    "gemini": {
      "image": "gemini-cli-sandbox:golang",
      "user": "node"
    },
    "claude": {
      "image": "claude-code:latest",
      "user": "node"
    }
  },
  "profiles": {
    "local": {
      "runtime": "container",
      "tmux": true
    },
    "remote": {
      "runtime": "kubernetes",
      "tmux": false,
      "harness_overrides": {
        "gemini": {
          "image": "us-docker.pkg.dev/gemini-code-dev/gemini-cli/sandbox:0.22.4"
          }
        }
    }
  }
}
